rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // wordcloud_words 集合：僅允許 2026-05-17 台北 16:00-17:00 讀寫
    // = UTC 2026-05-17 08:00-09:00
    match /wordcloud_words/{document} {
      allow read, write: if
        request.time >= timestamp.date(2026, 5, 17) + duration.value(8, 'h') &&
        request.time <  timestamp.date(2026, 5, 17) + duration.value(9, 'h');
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
